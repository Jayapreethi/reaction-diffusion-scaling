    "experiment": {
      "name": "Fisher-KPP GPU vs CPU Scaling Study",
      "version": "1.0",
      "description": "Systematic performance and physics validation across grid sizes",
      "date": "2026-07-16",
      "contact": "jayapreethi.mohan@und.edu"
    },
    "physics": {
      "pde": "Fisher-KPP reaction-diffusion",
      "domain_type": "2D rectangular",
      "boundary_conditions": "zero-flux (reflecting)",
      "diffusion_coefficient": 0.1,
      "reaction_rate": 0.5,
      "timestep": 0.01,
      "equation": "\u00e2\u02c6\u201au/\u00e2\u02c6\u201at = D\u00e2\u02c6\u2021\u00c2\u00b2u + ku(1-u)"
    },
    "grids": [
      {
        "size": [
          128,
          128
        ],
        "elements": 16384,
        "description": "Small: GPU overhead dominates"
      },
      {
        "size": [
          256,
          256
        ],
        "elements": 65536,
        "description": "Medium: Near breakeven point"
      },
      {
        "size": [
          512,
          512
        ],
        "elements": 262144,
        "description": "Large: GPU speedup visible"
      },
      {
        "size": [
          1024,
          1024
        ],
        "elements": 1048576,
        "description": "Very large: GPU strongly preferred"
      }
    ],
    "benchmarking": {
      "timesteps": 50,
      "runs_per_grid": 5,
      "synchronization": "proper",
      "statistical_metric": "median"
    },
    "validation": {
      "conservation_check": true,
      "tolerance_conservation": "1e-5",
      "accuracy_check": true,
      "max_l2_error": "1e-7",
      "cfl_check": true,
      "stability_margin": 0.8
    },
    "resources": {
      "cpu": {
        "device": "cpu",
        "backend": "pytorch"
      },
      "gpu": {
        "device": "cuda:0",
        "backend": "pytorch",
        "hardware": "Tesla V100-SXM2-32GB",
        "compute_capability": "7.0"
      }
    },
    "slurm": {
      "partition": "talon-gpu32",
      "time_limit": "00:30:00",
      "gpu_type": "v100",
      "cores": 4,
      "memory": "16GB",
      "email_notifications": true
    },
    "output": {
      "base_directory": "outputs",
      "results_format": [
        "json",
        "csv",
        "markdown"
      ],
      "timestamp_outputs": true,
      "keep_intermediate": true
    },
    "reproducibility": {
      "git_commit": "auto",
      "environment_capture": true,
      "random_seed": 42,
      "create_metadata": true
    }
